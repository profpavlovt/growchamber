		(at 25.4 51.816 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "04c6752f-e05e-4e5d-ba71-94810818ffa7")
	)
	(text "1. Place the high current paths (GND, VIN,\nand SW) as close to the device as possible\nwith short, direct, and wide traces.\n2. Place the input capacitor as close to IN and\nGND as possible (recommended within\n1mm).\n3. Place the external feedback resistors next\nto FB.\n4. Keep the switching node (SW) short and\naway from the feedback network."
		(exclude_from_sim no)
		(at 51.308 -20.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "0594f1be-5b13-43dc-b12e-b45deaa493af")
	)
	(text "12V to 5V switching converter.\n"
		(exclude_from_sim no)
		(at 62.23 18.034 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "524a01d2-3e1a-423e-b7b4-b996b68c09d8")
	)
	(text "5V to 3.3V power for ESP32"
		(exclude_from_sim no)
		(at 155.956 15.24 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "99b2e066-5ec3-404e-9c1e-35afdcc48993")
	)
	(text "TX and RX need to be \nswapped on the silkscreen\n"
		(exclude_from_sim no)
		(at 94.234 76.2 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "d0e9dec9-5a8d-4a25-b7de-fa6d75acfa96")
	)
