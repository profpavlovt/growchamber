	(text "Place capacitors within 1mm of IN/GND pins."
		(exclude_from_sim no)
		(at 26.416 7.112 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "04c6752f-e05e-4e5d-ba71-94810818ffa7")
	)
	(text "1. Place the high current paths (GND, VIN,\nand SW) as close to the device as possible\nwith short, direct, and wide traces.\n2. Place the input capacitor as close to IN and\nGND as possible (recommended within\n1mm).\n3. Place the external feedback resistors next\nto FB.\n4. Keep the switching node (SW) short and\naway from the feedback network."
		(exclude_from_sim no)
		(at 51.308 -20.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
